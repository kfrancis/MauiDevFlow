<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>

    <PackageId>Redth.MauiDevFlow.Agent.Core</PackageId>
    <Description>Core agent infrastructure for MauiDevFlow. HTTP server, visual tree walking, logging, and element interaction — platform-agnostic.</Description>
    <PackageTags>maui;automation;testing;agent;core</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Fizzler" Version="1.3.0" />
    <PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
    <PackageReference Include="SkiaSharp" Version="3.119.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MauiDevFlow.Logging\MauiDevFlow.Logging.csproj" />
  </ItemGroup>

</Project>
